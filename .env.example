# Server
PORT=3000

# Devin API — when set, failing actions create a real Devin session that
# investigates and opens a PR. When unset, the pipeline runs in simulated mode
# and logs the prompt it would have sent.
DEVIN_API_KEY=
DEVIN_API_BASE=https://api.devin.ai

# Force simulated mode even if DEVIN_API_KEY is set.
SIMULATE_PIPELINE=

# Optional integrations (best-effort, no-op when unset).
SLACK_WEBHOOK_URL=
SENTRY_DSN=

# Public config surfaced at /api/config (mirrors the reference hub).
APP_TITLE=Event-Driven Devin
DEFAULT_ORG_ID=
DEFAULT_ORG_NAME=
DEFAULT_USER_ID=
LOCK_ORG=
LOCK_USER=

# Global cap on Devin sessions created within a rolling window.
SESSION_CAP_MAX=5
SESSION_CAP_WINDOW_MINUTES=60
